# Email Configuration
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Admin Dashboard
ADMIN_PASSWORD=your-secure-password

# App Configuration
APP_URL=https://your-streamlit-app-url.streamlit.app
DATABASE_PATH=seo_audits.db

# ── Social Media API Credentials (optional) ─────────────────────────────────
# Leave blank to run without live API data (manual entry still works).

# Instagram (instagrapi) — use a secondary/dedicated account, not your main one
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# TikTok (TikTokApi) — extract ms_token cookie from a logged-in TikTok browser session
TIKTOK_MS_TOKEN=

# YouTube Data API v3 — create at https://console.cloud.google.com
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# LinkedIn OAuth 2.0 — create app at https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
